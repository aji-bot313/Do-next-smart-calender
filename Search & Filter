    for (char &c : categoryt) c = tolower(static_cast<unsigned char>(c));
    for (int i = 0; i < taskCount; i++){
        string pStr = (taskList[i].importance == 1 ? "high" : (taskList[i].importance == 2 ? "medium" : "low"));
